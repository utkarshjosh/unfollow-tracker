# Server
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/unfollow_tracker?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h

# Instagram Scraping
SCRAPE_DELAY_MS=2000
MAX_CONCURRENT_FETCHERS=4
PROXY_POOL_URL=

# Notifications
NOTIFICATION_DELAY_HOURS=6
ENABLE_PUSH_NOTIFICATIONS=false

# Stripe (for SaaS billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend
VITE_API_URL=http://localhost:8080
